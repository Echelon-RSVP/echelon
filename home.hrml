<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#FCF6FA">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Echelon" />
  <link rel="manifest" href="/app/manifest.webmanifest" />
  <link rel="icon" type="image/png" sizes="32x32" href="/app/icons/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/app/icons/icon-192.png" />
  <link rel="apple-touch-icon" href="/app/icons/apple-touch-icon.png" />
  <title>Echelon | Measurable Authenticity</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Quicksand:wght@500;600;700&display=swap');

    :root {
      --bg-light: #FCF6FA;
      --text-main: #5A4A60;
      --text-muted: #9B8FA8;
      --pink-grad: linear-gradient(135deg, #FF9DC0, #B79CF0);
      --gold-grad: linear-gradient(135deg, #FFE9A8, #FFD1E1);
      --glass-bg: rgba(255, 255, 255, 0.35);
      --glass-border: rgba(255, 255, 255, 0.6);
      --glass-shadow: 0 32px 64px rgba(150, 110, 140, 0.15);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      -webkit-font-smoothing: antialiased;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      color: var(--text-main);
      background-color: var(--bg-light);
      overflow-x: hidden;
      line-height: 1.6;
      scroll-behavior: smooth;
      overscroll-behavior-y: none;
      -webkit-text-size-adjust: 100%;
    }

    h1, h2, h3, h4, .font-brand {
      font-family: 'Quicksand', sans-serif;
    }

    ::selection {
      background: #FFD1E1;
      color: #5A4A60;
    }

    .aurora-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      z-index: -2;
      pointer-events: none;
      background-color: #fdfafc;
      overflow: hidden;
    }

    .aurora-blob {
      position: absolute;
      filter: blur(80px);
      border-radius: 50%;
      animation: floatBlob 20s infinite alternate ease-in-out;
      opacity: 0.6;
      mix-blend-mode: multiply;
    }

    .blob-1 { top: -10%; left: -10%; width: 60vw; height: 60vw; background: #FFE3EE; animation-delay: 0s; }
    .blob-2 { top: 40%; right: -20%; width: 70vw; height: 70vw; background: #E4ECFF; animation-delay: -5s; }
    .blob-3 { bottom: -20%; left: 20%; width: 50vw; height: 50vw; background: #FFF0DD; animation-delay: -10s; }

    @keyframes floatBlob {
      0% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(5%, -5%) scale(1.1); }
      66% { transform: translate(-5%, 5%) scale(0.9); }
      100% { transform: translate(0, 0) scale(1); }
    }

    .ambient-grid {
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background-size: 40px 40px;
      background-image: 
        linear-gradient(to right, rgba(255,255,255,0.6) 1px, transparent 1px), 
        linear-gradient(to bottom, rgba(255,255,255,0.6) 1px, transparent 1px);
      mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
      -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
    }

    #cursor-glow {
      position: fixed;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(255,255,255,0.8) 0%, rgba(255,157,192,0.1) 40%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      z-index: -1;
      transform: translate(-50%, -50%);
      transition: top 0.15s ease-out, left 0.15s ease-out;
      mix-blend-mode: screen;
    }

    header {
      background: rgba(255, 255, 255, 0.4);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--glass-border);
      box-shadow: 0 4px 30px rgba(0,0,0,0.02);
    }

    .text-gradient {
      background: var(--pink-grad);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .btn-glass {
      background: rgba(255, 255, 255, 0.5);
      backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      box-shadow: 0 8px 32px rgba(180, 150, 190, 0.15);
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
      color: var(--text-main);
    }
    .btn-glass:hover {
      background: rgba(255, 255, 255, 0.9);
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 16px 40px rgba(180, 150, 190, 0.25);
    }
    .btn-glass:active { transform: scale(0.96); }

    .btn-primary {
      background: linear-gradient(135deg, #FF9DC0, #B79CF0);
      color: white;
      box-shadow: 0 12px 28px rgba(255, 157, 192, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.4);
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .btn-primary:hover {
      box-shadow: 0 16px 36px rgba(183, 156, 240, 0.5);
      transform: translateY(-3px) scale(1.02);
      filter: brightness(1.05);
    }
    .btn-primary:active { transform: scale(0.96); }

    .btn-apple {
      background: #0d0d0f;
      color: #fff;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .btn-apple:hover {
      box-shadow: 0 16px 36px rgba(0, 0, 0, 0.35);
      transform: translateY(-3px) scale(1.02);
    }
    .btn-apple:active { transform: scale(0.96); }

    .hero-perspective {
      perspective: 1200px;
    }

    .hero-visual-card {
      width: 340px;
      height: 480px;
      background: linear-gradient(145deg, rgba(255,255,255,0.7), rgba(255,255,255,0.2));
      border-radius: 48px;
      backdrop-filter: blur(40px);
      -webkit-backdrop-filter: blur(40px);
      border: 1px solid var(--glass-border);
      box-shadow: var(--glass-shadow), inset 0 0 0 2px rgba(255,255,255,0.5), inset 0 0 40px rgba(255,255,255,0.8);
      position: relative;
      transform-style: preserve-3d;
      transition: transform 0.1s ease-out;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .hero-visual-card::before {
      content: '';
      position: absolute;
      inset: -30px;
      background: conic-gradient(from 180deg, #F4C84B, #FF9DC0, #7FB8F0, #B79CF0, #F4C84B);
      border-radius: 50%;
      filter: blur(50px);
      opacity: 0.5;
      z-index: -1;
      animation: spin 12s linear infinite;
    }

    .card-content-3d {
      transform: translateZ(80px); /* Pushes content out from the glass */
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .score-ring {
      width: 200px;
      height: 200px;
      border-radius: 50%;
      border: 8px solid transparent;
      background: linear-gradient(white, white) padding-box, 
                  linear-gradient(135deg, #F4C84B, #FF9DC0, #7FB8F0) border-box;
      display: grid;
      place-items: center;
      margin-bottom: 24px;
      position: relative;
      box-shadow: inset 0 0 30px rgba(244, 200, 75, 0.2), 0 20px 40px rgba(255, 157, 192, 0.3);
    }

    .score-ring::after {
      content: '';
      position: absolute;
      inset: -16px;
      border-radius: 50%;
      border: 2px dashed rgba(217, 166, 37, 0.5);
      animation: spin 25s linear infinite reverse;
    }

    .marquee-container {
      width: 100vw;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(20px);
      border-top: 1px solid rgba(255,255,255,0.8);
      border-bottom: 1px solid rgba(255,255,255,0.8);
      padding: 14px 0;
      position: relative;
      display: flex;
      box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .marquee-content {
      display: flex;
      white-space: nowrap;
      animation: scrollMarquee 35s linear infinite;
    }

    .marquee-item {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 4px 24px;
      font-size: 14px;
      font-weight: 600;
      color: var(--text-main);
      border-right: 1px solid rgba(155, 143, 168, 0.2);
    }

    @keyframes scrollMarquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .glass-panel {
      background: rgba(255, 255, 255, 0.4);
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
      border: 1px solid var(--glass-border);
      border-radius: 40px;
      box-shadow: var(--glass-shadow), inset 0 0 0 1px rgba(255,255,255,0.5);
      transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    .reveal {
      opacity: 0;
      transform: translateY(50px) scale(0.95);
      transition: all 1s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .reveal.active {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }

    .sparkle {
      position: absolute;
      color: #FF9DC0;
      animation: twinkle 2s infinite ease-in-out alternate;
      pointer-events: none;
      z-index: -1;
    }
    @keyframes twinkle {
      0% { opacity: 0.2; transform: scale(0.6) rotate(0deg); }
      100% { opacity: 1; transform: scale(1.2) rotate(20deg); }
    }

    .langtabs { display: flex; flex-wrap: nowrap; gap: 2px; align-items: center; padding: 2px; border-radius: 999px; background: rgba(255,255,255,.55); border: 1px solid rgba(255,255,255,.85); backdrop-filter: blur(8px); }
    .langtab {
      min-width: 0; width: 28px; height: 24px; padding: 0; border-radius: 999px;
      border: none; background: transparent;
      color: #8B7A96; font-weight: 700; font-size: 9px; cursor: pointer; letter-spacing: .03em;
      transition: transform .12s, background .12s, box-shadow .12s;
    }
    .langtab.on {
      background: linear-gradient(135deg, #FF9DC0, #B79CF0);
      color: #fff;
      box-shadow: 0 2px 8px rgba(183,156,240,.28);
    }
    .langtab:active { transform: scale(.94); }

    .legal-footer-links { display: flex; flex-wrap: wrap; gap: 10px 18px; justify-content: center; align-items: center; margin: 20px 0 14px; font-size: 13px; font-weight: 700; }
    .legal-footer-links a { color: #8C6BD8; text-decoration: underline; white-space: nowrap; }
    .legal-footer-links a:hover { color: #6B4FA8; }
    .home-footer-tagline { font-size: 13px; font-weight: 700; color: #8B7A95; margin-bottom: 8px; max-width: 28rem; margin-left: auto; margin-right: auto; }
    .home-footer-copy { font-size: 11px; color: #9B8FA8; letter-spacing: 0.02em; max-width: 32rem; margin-left: auto; margin-right: auto; }

    .cookie-banner-home { position: fixed; bottom: 0; left: 0; right: 0; z-index: 100; padding: 16px; pointer-events: none; }
    .cookie-banner-home-inner { pointer-events: auto; max-width: 720px; margin: 0 auto; background: rgba(255,251,254,.97); border: 1px solid rgba(235,217,240,.9); border-radius: 20px; padding: 18px 20px; box-shadow: 0 -8px 40px rgba(120,80,110,.2); backdrop-filter: blur(14px); }
    .cookie-banner-home-inner h3 { font-family: Quicksand; font-size: 16px; color: #5A4A60; margin-bottom: 8px; }
    .cookie-banner-home-inner p { font-size: 13px; color: #7B6A86; line-height: 1.55; margin-bottom: 10px; }
    .cookie-banner-home-actions { display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end; margin-top: 12px; }
    .cookie-btn { padding: 10px 16px; border-radius: 14px; font-weight: 800; font-size: 13px; cursor: pointer; border: none; transition: transform .12s; }
    .cookie-btn:active { transform: scale(.96); }
    .cookie-btn-ghost { background: rgba(255,255,255,.8); border: 1px solid #EBD9F0; color: #7B6A86; }
    .cookie-btn-primary { background: linear-gradient(135deg, #FF9DC0, #B79CF0); color: #fff; box-shadow: 0 8px 20px rgba(183,156,240,.35); }
    .cookie-pref-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #F1E8F0; font-size: 13px; }
    .cookie-banner-links { display: flex; flex-wrap: wrap; gap: 8px 16px; font-size: 12px; font-weight: 700; }
    .cookie-banner-links a { color: #8C6BD8; text-decoration: underline; }

    .legal-modal-home { display: none; position: fixed; inset: 0; z-index: 110; background: rgba(90,74,96,.45); backdrop-filter: blur(6px); padding: 24px 16px; overflow: auto; }
    .legal-modal-home.open { display: flex; align-items: flex-start; justify-content: center; }
    .legal-modal-home-panel { background: #FFFBFE; border-radius: 24px; max-width: 720px; width: 100%; max-height: min(85vh, 800px); overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 24px 60px rgba(100,70,90,.25); }
    .legal-modal-home-head { display: flex; align-items: center; justify-content: space-between; padding: 18px 20px; border-bottom: 1px solid #F1E8F0; }
    .legal-modal-home-head h2 { font-family: Quicksand; margin: 0; font-size: 20px; color: #5A4A60; }
    .legal-modal-home-close { background: #F5EFF8; border: none; width: 36px; height: 36px; border-radius: 12px; cursor: pointer; font-size: 18px; color: #7B6A86; }
    .legal-modal-home-body { overflow: auto; padding: 16px 20px 28px; }
    .legal-modal-home-body h2 { font-family: Quicksand; font-size: 15px; color: #5A4A60; margin: 18px 0 8px; }
    .legal-modal-home-body p, .legal-modal-home-body li { font-size: 14px; line-height: 1.65; color: #6B5A76; margin-bottom: 10px; }
    .legal-modal-home-body ul { padding-left: 20px; margin-bottom: 12px; }
    .legal-updated { font-size: 12px; color: #9B8FA8; margin-bottom: 16px; }

    .mobile-app-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 7px 14px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
      text-decoration: none;
    }

    .a2hs-hero-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      width: 100%;
      padding: 18px 22px;
      border-radius: 22px;
      border: 2px solid rgba(255,255,255,.95);
      background: linear-gradient(135deg, #FFE9F2 0%, #E8E0FF 55%, #DCE8FF 100%);
      box-shadow: 0 16px 40px rgba(150,110,150,.2), inset 0 1px 0 rgba(255,255,255,.9);
      font-family: 'Nunito', sans-serif;
      font-weight: 900;
      font-size: 1.15rem;
      color: #4A3A58;
      cursor: pointer;
      transition: transform .12s;
      text-align: center;
    }
    .a2hs-hero-btn:active { transform: scale(.98); }
    .a2hs-hero-btn span.a2hs-sub {
      font-size: .78rem;
      font-weight: 700;
      color: #8B7A96;
      line-height: 1.35;
    }

    .a2hs-install-modal { display: none; position: fixed; inset: 0; z-index: 120; background: rgba(90,74,96,.45); backdrop-filter: blur(6px); padding: 24px 16px; align-items: flex-end; justify-content: center; }
    .a2hs-install-modal.open { display: flex; }
    .a2hs-install-panel { width: min(100%, 420px); background: #FFFBFE; border-radius: 28px 28px 0 0; padding: 18px 20px max(24px, env(safe-area-inset-bottom)); box-shadow: 0 -20px 60px rgba(100,70,90,.25); }
    .a2hs-install-panel h3 { font-family: Quicksand; font-size: 20px; color: #5A4A60; margin: 0 0 8px; text-align: center; }
    .a2hs-install-panel p.lead { font-size: 13px; color: #8B7A96; text-align: center; margin: 0 0 14px; line-height: 1.5; }
    .a2hs-install-steps { list-style: none; padding: 0; margin: 0 0 14px; display: flex; flex-direction: column; gap: 10px; }
    .a2hs-install-steps li { font-size: 13.5px; font-weight: 700; color: #5A4A60; padding: 12px 14px; border-radius: 16px; background: #FBF4FB; border: 1px solid #F1E5F1; line-height: 1.45; }

    .hero-mobile-card {
      display: none;
      width: min(280px, 88vw);
      margin: 0 auto 24px;
      padding: 20px 18px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.55);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid var(--glass-border);
      box-shadow: var(--glass-shadow);
      text-align: center;
    }

    .hero-mobile-score {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      margin: 0 auto 12px;
      border: 6px solid transparent;
      background: linear-gradient(white, white) padding-box,
                  linear-gradient(135deg, #F4C84B, #FF9DC0, #7FB8F0) border-box;
      display: grid;
      place-items: center;
      font-family: 'Quicksand', sans-serif;
      font-size: 2.25rem;
      font-weight: 700;
      color: #D9A625;
    }

    @media (max-width: 767px) {
      .aurora-bg { height: 100dvh; }
      header { padding-left: max(16px, env(safe-area-inset-left)); padding-right: max(16px, env(safe-area-inset-right)); }
      .hero-mobile-card { display: block; }
      .marquee-item { font-size: 12px; padding: 4px 16px; }
      .glass-panel { border-radius: 28px; }
      .glass-panel:hover { transform: none; }
      .cookie-banner-home {
        padding: 12px;
        padding-bottom: max(12px, env(safe-area-inset-bottom));
      }
      .cookie-banner-home-inner { padding: 16px; border-radius: 18px; }
      .cookie-banner-home-actions { flex-direction: column; align-items: stretch; }
      .cookie-banner-home-actions .cookie-btn { width: 100%; text-align: center; justify-content: center; }
      .legal-modal-home { padding: 16px 12px; padding-bottom: max(16px, env(safe-area-inset-bottom)); }
      .sparkle { display: none; }
    }

    @media (max-width: 480px) {
      .hero-mobile-score { width: 100px; height: 100px; font-size: 1.85rem; }
    }

    @media (hover: hover) and (pointer: fine) {
      .glass-panel:hover {
        transform: translateY(-12px);
        background: rgba(255, 255, 255, 0.6);
        box-shadow: 0 40px 80px rgba(150, 110, 140, 0.2), inset 0 0 0 1px rgba(255,255,255,0.8);
      }
    }

    .brand-lockup { text-decoration: none; color: inherit; }
    .brand-logo {
      border-radius: 14px;
      box-shadow: 0 8px 22px rgba(150, 110, 150, 0.18), inset 0 0 0 2px rgba(255,255,255,0.85);
      object-fit: cover;
    }

    .hero-logo-wrap {
      position: relative;
      width: 88px;
      height: 88px;
      margin: 0 auto 20px;
    }
    @media (min-width: 768px) {
      .hero-logo-wrap { margin: 0 0 24px; }
    }
    .hero-logo-glow {
      position: absolute;
      inset: -16px;
      border-radius: 28px;
      background: conic-gradient(from 200deg, #FFE9A8, #FF9DC0, #B79CF0, #7FB8F0, #FFE9A8);
      filter: blur(20px);
      opacity: 0.55;
      animation: heroLogoGlow 6s ease-in-out infinite alternate;
    }
    .hero-logo {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
      border-radius: 22px;
      box-shadow: 0 14px 36px rgba(150, 110, 150, 0.22), inset 0 0 0 2px rgba(255,255,255,0.85);
      object-fit: cover;
    }
    @keyframes heroLogoGlow {
      0% { transform: scale(0.92) rotate(0deg); opacity: 0.45; }
      100% { transform: scale(1.06) rotate(12deg); opacity: 0.62; }
    }

    .hero-card-logo {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      margin-bottom: 14px;
      box-shadow: 0 8px 20px rgba(150, 110, 150, 0.15);
    }

    .how-step-num {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      font-family: 'Quicksand', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: #fff;
      background: linear-gradient(135deg, #FF9DC0, #B79CF0);
      box-shadow: 0 8px 20px rgba(255, 157, 192, 0.35);
      margin-bottom: 16px;
    }

    .faq-list {
      max-width: 760px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .faq-item {
      background: rgba(255, 255, 255, 0.5);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 0 20px;
      box-shadow: 0 12px 32px rgba(150, 110, 140, 0.08);
    }
    .faq-item summary {
      cursor: pointer;
      list-style: none;
      font-weight: 800;
      font-size: 1rem;
      color: #5A4A60;
      padding: 18px 28px 18px 0;
      position: relative;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after {
      content: '+';
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1.4rem;
      font-weight: 700;
      color: #B79CF0;
      transition: transform 0.2s;
    }
    .faq-item[open] summary::after { transform: translateY(-50%) rotate(45deg); }
    .faq-item p {
      margin: 0 0 18px;
      font-size: 0.95rem;
      line-height: 1.65;
      color: #8B7A96;
      font-weight: 500;
    }
    .faq-docs-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 28px;
      font-weight: 800;
      color: #9B7CC0;
      text-decoration: none;
      padding: 12px 20px;
      border-radius: 16px;
      background: rgba(255,255,255,0.55);
      border: 1px solid var(--glass-border);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .faq-docs-link:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 28px rgba(150, 110, 140, 0.12);
    }

  </style>
</head>
