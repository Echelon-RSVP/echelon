  <section id="features" class="py-16 sm:py-24 md:py-32 px-4 sm:px-6 md:px-12 max-w-[1400px] mx-auto relative z-10">
    <div class="text-center mb-10 sm:mb-16 md:mb-20 reveal">
      <h2 class="text-3xl sm:text-5xl md:text-6xl font-bold text-gray-800 mb-4 sm:mb-6 tracking-tight px-2" data-i18n="home.features.title">A perfectly curated reality.</h2>
      <p class="text-base sm:text-xl text-gray-500 max-w-3xl mx-auto font-medium leading-relaxed px-2" data-i18n="home.features.lead">When everyone is held accountable in real time, the world becomes a warmer, brighter, and more polite place to exist.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8 md:gap-10">
      
      <!-- Card 1 -->
      <div class="glass-panel p-7 sm:p-10 md:p-12 reveal tilt-feature">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-pink-200 rounded-full mix-blend-multiply filter blur-3xl opacity-60"></div>
        <div class="w-20 h-20 rounded-3xl flex items-center justify-center mb-8 shadow-lg relative z-10" style="background: linear-gradient(135deg, #FF9DC0, #B79CF0);">
          <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <h3 class="text-2xl sm:text-3xl font-bold mb-3 sm:mb-4 text-gray-800 relative z-10" data-i18n="home.features.c1t">Radical Transparency</h3>
        <p class="text-gray-500 font-medium leading-relaxed text-base sm:text-lg relative z-10" data-i18n="home.features.c1d">Activate the AR Lens Overlay to see everyone's score floating in real time. Know exactly who you are interacting with before you even speak.</p>
      </div>

      <!-- Card 2 -->
      <div class="glass-panel p-7 sm:p-10 md:p-12 reveal tilt-feature" style="transition-delay: 0.1s;">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-yellow-200 rounded-full mix-blend-multiply filter blur-3xl opacity-60"></div>
        <div class="w-20 h-20 rounded-3xl flex items-center justify-center mb-8 shadow-lg relative z-10" style="background: linear-gradient(135deg, #FFE9A8, #FFD1E1);">
          <svg class="w-10 h-10 text-yellow-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m2 4 3 12h14l3-12-6 7-4-7-4 7-6-7zm3 16h14"/></svg>
        </div>
        <h3 class="text-2xl sm:text-3xl font-bold mb-3 sm:mb-4 text-gray-800 relative z-10" data-i18n="home.features.c2t">Curated Lifestyle</h3>
        <p class="text-gray-500 font-medium leading-relaxed text-base sm:text-lg relative z-10" data-i18n="home.features.c2d">Your score is your key. Elite members unlock priority travel lanes, fine dining reservations, and exclusive housing communities seamlessly.</p>
      </div>

      <!-- Card 3 -->
      <div class="glass-panel p-7 sm:p-10 md:p-12 reveal tilt-feature" style="transition-delay: 0.2s;">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-green-200 rounded-full mix-blend-multiply filter blur-3xl opacity-60"></div>
        <div class="w-20 h-20 rounded-3xl flex items-center justify-center mb-8 shadow-lg relative z-10" style="background: linear-gradient(135deg, #7FD4B4, #BFE08A);">
          <svg class="w-10 h-10 text-green-800" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"/></svg>
        </div>
        <h3 class="text-2xl sm:text-3xl font-bold mb-3 sm:mb-4 text-gray-800 relative z-10" data-i18n="home.features.c3t">Instant Harmony</h3>
        <p class="text-gray-500 font-medium leading-relaxed text-base sm:text-lg relative z-10" data-i18n="home.features.c3d">Keep your interactions warm, polite, and accountable. Our proprietary algorithm ensures the world stays beautifully kind.</p>
      </div>

      <!-- Card 4 -->
      <div class="glass-panel p-7 sm:p-10 md:p-12 reveal tilt-feature" style="transition-delay: 0.3s;">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-60"></div>
        <div class="w-20 h-20 rounded-3xl flex items-center justify-center mb-8 shadow-lg relative z-10" style="background: linear-gradient(135deg, #B79CF0, #FF9DC0);">
          <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </div>
        <h3 class="text-2xl sm:text-3xl font-bold mb-3 sm:mb-4 text-gray-800 relative z-10" data-i18n="home.features.c4t">Earned ratings</h3>
        <p class="text-gray-500 font-medium leading-relaxed text-base sm:text-lg relative z-10" data-i18n="home.features.c4d">Only members with a higher score can rate someone lower. Every star shifts the curve, so warmth and accountability stay meaningful.</p>
      </div>

    </div>
  </section>

  <section id="how" class="py-16 sm:py-24 md:py-28 px-4 sm:px-6 md:px-12 max-w-[1200px] mx-auto relative z-10">
    <div class="text-center mb-10 sm:mb-16 reveal">
      <h2 class="text-3xl sm:text-5xl md:text-6xl font-bold text-gray-800 mb-4 sm:mb-6 tracking-tight px-2" data-i18n="home.how.title">Three steps to measurable you</h2>
      <p class="text-base sm:text-xl text-gray-500 max-w-3xl mx-auto font-medium leading-relaxed px-2" data-i18n="home.how.lead">Sign in, establish your baseline, then let the community refine your score every day.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
      <div class="glass-panel p-7 sm:p-9 reveal">
        <div class="how-step-num">1</div>
        <h3 class="text-xl sm:text-2xl font-bold mb-3 text-gray-800" data-i18n="home.how.s1t">Sign in &amp; scan</h3>
        <p class="text-gray-500 font-medium leading-relaxed" data-i18n="home.how.s1d">Apple, Gmail, or email. One quick face scan sets your starting Echelon Score™.</p>
      </div>
      <div class="glass-panel p-7 sm:p-9 reveal" style="transition-delay: 0.1s;">
        <div class="how-step-num">2</div>
        <h3 class="text-xl sm:text-2xl font-bold mb-3 text-gray-800" data-i18n="home.how.s2t">Rate with hierarchy</h3>
        <p class="text-gray-500 font-medium leading-relaxed" data-i18n="home.how.s2d">Higher scores rate lower ones. Thoughtful stars move the needle; noise stays filtered out.</p>
      </div>
      <div class="glass-panel p-7 sm:p-9 reveal" style="transition-delay: 0.2s;">
        <div class="how-step-num">3</div>
        <h3 class="text-xl sm:text-2xl font-bold mb-3 text-gray-800" data-i18n="home.how.s3t">Unlock perks</h3>
        <p class="text-gray-500 font-medium leading-relaxed" data-i18n="home.how.s3d">Travel lanes, dining, gatherings, and premium feed tiers follow your score.</p>
      </div>
    </div>
  </section>

  <section id="faq" class="py-16 sm:py-24 md:py-28 px-4 sm:px-6 md:px-12 max-w-[1000px] mx-auto relative z-10">
    <div class="text-center mb-10 sm:mb-14 reveal">
      <h2 class="text-3xl sm:text-5xl font-bold text-gray-800 mb-4 tracking-tight" data-i18n="home.faq.title">Frequently asked questions</h2>
    </div>
    <div class="faq-list reveal">
      <details class="faq-item">
        <summary data-i18n="faq.q1">How is my Echelon Score™ calculated?</summary>
        <p data-i18n="faq.a1">Your score is a holistic reflection of how the community experiences you.</p>
      </details>
      <details class="faq-item">
        <summary data-i18n="faq.q2">Why do high-tier ratings count more?</summary>
        <p data-i18n="faq.a2">Esteemed members have demonstrated sustained warmth, so their perception carries proportionally greater signal.</p>
      </details>
      <details class="faq-item">
        <summary data-i18n="faq.q3">Why did my score drop after a kind interaction?</summary>
        <p data-i18n="faq.a3">Sometimes growth feels uncomfortable. A dip is simply an invitation to lean further into positivity.</p>
      </details>
      <details class="faq-item">
        <summary data-i18n="faq.q4">Can I see who rated me low?</summary>
        <p data-i18n="faq.a4">We protect every member's right to honest, frictionless expression.</p>
      </details>
      <details class="faq-item">
        <summary data-i18n="faq.q5">Does Echelon ever delete a rating?</summary>
        <p data-i18n="faq.a5">Ratings are authentic sentiment and are therefore permanent-ish.</p>
      </details>
    </div>
    <div class="text-center reveal">
      <a href="/app/docs.html" class="faq-docs-link" data-i18n="home.faq.docs">Read the full in-app guide →</a>
    </div>
  </section>

  <section id="elite" class="py-14 sm:py-20 md:py-24 px-4 sm:px-6 md:px-12 text-center max-w-6xl mx-auto relative z-10">
    <div class="reveal">
      <h2 class="text-3xl sm:text-5xl md:text-6xl font-bold text-gray-800 mb-8 sm:mb-12 md:mb-16 tracking-tight px-2" data-i18n="home.elite.title">Beloved by the best of us.</h2>
    </div>
    
    <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-5 sm:gap-8">
      
      <div class="glass-panel p-6 sm:p-8 w-full sm:max-w-md text-left reveal">
        <div class="flex items-center gap-5 mb-6">
          <div class="w-16 h-16 rounded-full bg-gradient-to-br from-yellow-200 to-pink-200 flex items-center justify-center text-4xl border-4 border-white shadow-md relative">
            😍
            <div class="absolute -bottom-2 -right-2 bg-white rounded-full p-1 shadow-sm">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-yellow-500"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            </div>
          </div>
          <div>
            <div class="font-extrabold text-xl text-gray-800">Iris Moon</div>
            <div class="text-yellow-600 font-bold text-sm bg-yellow-100/50 px-3 py-1 rounded-full inline-block mt-1">
              4.9 Elite
            </div>
          </div>
        </div>
        <p class="text-gray-600 font-medium text-lg leading-relaxed">"Since reaching Elite, life just flows. Doors open, smiles are brighter. Echelon is not just an app. It is a commitment to a beautiful existence."</p>
      </div>

      <div class="glass-panel p-6 sm:p-8 w-full sm:max-w-md text-left reveal" style="transition-delay: 0.1s;">
        <div class="flex items-center gap-5 mb-6">
          <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-100 to-purple-200 flex items-center justify-center text-4xl border-4 border-white shadow-md relative">
            😁
            <div class="absolute -bottom-2 -right-2 bg-white rounded-full p-1 shadow-sm">
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-purple-500"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            </div>
          </div>
          <div>
            <div class="font-extrabold text-xl text-gray-800">Theo Brightman</div>
            <div class="text-purple-600 font-bold text-sm bg-purple-100/50 px-3 py-1 rounded-full inline-block mt-1">
              4.5 High
            </div>
          </div>
        </div>
        <p class="text-gray-600 font-medium text-lg leading-relaxed">"The priority travel lane alone is worth every warm interaction. Echelon keeps me motivated to always show up as my very best self."</p>
      </div>

    </div>
  </section>

  <footer id="download" class="pt-16 sm:pt-24 md:pt-32 pb-12 sm:pb-16 md:pb-20 text-center relative mt-10 sm:mt-16 md:mt-20 bg-white/40 backdrop-blur-2xl border-t border-white/60" style="padding-bottom: max(48px, env(safe-area-inset-bottom));">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 reveal">
      <h2 class="text-2xl sm:text-4xl md:text-5xl font-bold text-gray-800 mb-6 sm:mb-8 tracking-tight" data-i18n="home.footer.title">Ready to be measured?</h2>
      
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:gap-5 mb-10 sm:mb-16">
        <button type="button" id="a2hs-footer-btn" class="a2hs-hero-btn" style="max-width:420px;margin:0 auto">
          <span data-i18n="home.hero.install">Add to Home Screen 📲</span>
          <span class="a2hs-sub" data-i18n="home.hero.installSub">Install Echelon like an app. One tap to open.</span>
        </button>
        <a href="/app/" class="btn-glass flex items-center gap-3 px-8 sm:px-10 py-4 sm:py-5 rounded-2xl font-extrabold text-lg sm:text-xl w-full sm:w-auto justify-center" data-i18n="home.hero.visit">
          Open in browser ✨
        </a>
      </div>
      
      <a href="#" class="brand-lockup flex items-center justify-center gap-3 mb-6">
        <img src="/app/icons/icon-192.png" alt="" width="44" height="44" class="brand-logo" />
        <span class="font-brand text-2xl font-bold tracking-tight text-gradient">echelon</span>
      </a>
      <nav class="legal-footer-links" aria-label="Legal">
        <a href="/privacy.html" data-i18n="legal.privacy">Privacy Policy</a>
        <a href="/terms.html" data-i18n="legal.terms">Terms &amp; Conditions</a>
        <a href="/cookies.html" data-i18n="legal.cookies">Cookie Policy</a>
        <a href="/data-deletion.html" data-i18n="legal.dataDeletion">Data deletion</a>
        <a href="/cookies.html#settings" data-i18n="legal.cookieSettings">Cookie settings</a>
      </nav>
      <p class="text-sm text-gray-500 font-bold mb-3 max-w-lg mx-auto" data-i18n="home.footer.consent">By downloading or visiting the app, you consent to continuous, real time evaluation and public display of your metric identity.</p>
      <p class="home-footer-tagline" data-i18n="home.footer.tagline">Reputation as currency, by design.</p>
      <p class="home-footer-email"><a href="mailto:hi@echelon.rsvp">hi@echelon.rsvp</a></p>
      <p class="home-footer-copy" data-i18n="home.footer.copy">© 2026 Fortune Comet, Unipessoal Lda (VAT PT516161440). All rights reserved.</p>
    </div>
  </footer>

  <div id="cookie-banner" class="cookie-banner-home" role="dialog" aria-labelledby="cookie-title" hidden>
    <div class="cookie-banner-home-inner">
      <h3 id="cookie-title" data-i18n="cookie.banner.title">We value your privacy</h3>
      <p data-i18n="cookie.banner.text">We use strictly necessary storage and, with your consent, functional preferences.</p>
      <div class="cookie-banner-links" style="margin:0 0 4px">
        <a href="/privacy.html" data-i18n="legal.privacy">Privacy Policy</a>
        <a href="/cookies.html" data-i18n="legal.cookies">Cookie Policy</a>
      </div>
      <div id="cookie-prefs-panel" hidden>
        <label class="cookie-pref-row"><span data-i18n="cookie.functional">Functional storage</span><input type="checkbox" id="cookie-functional" checked></label>
        <label class="cookie-pref-row muted" style="opacity:.7"><span data-i18n="cookie.analytics">Analytics</span><input type="checkbox" disabled></label>
      </div>
      <div class="cookie-banner-home-actions">
        <button type="button" class="cookie-btn cookie-btn-ghost" id="cookie-reject" data-i18n="cookie.reject">Reject non-essential</button>
        <button type="button" class="cookie-btn cookie-btn-ghost" id="cookie-manage" data-i18n="cookie.manage">Manage preferences</button>
        <button type="button" class="cookie-btn cookie-btn-primary" id="cookie-accept" data-i18n="cookie.acceptAll">Allow functional</button>
        <button type="button" class="cookie-btn cookie-btn-primary" id="cookie-save" hidden data-i18n="cookie.save">Save preferences</button>
      </div>
    </div>
  </div>

  <div id="a2hs-modal" class="a2hs-install-modal" aria-hidden="true">
    <div class="a2hs-install-panel">
      <h3 data-i18n="pwa.addToHome">Add to Home Screen</h3>
      <p class="lead" data-i18n="pwa.helpLead">Install Echelon on your home screen for one-tap access:</p>
      <ol class="a2hs-install-steps" id="a2hs-steps"></ol>
      <a href="/app/?install=1" class="btn-primary flex items-center justify-center gap-2 px-6 py-3.5 rounded-2xl font-extrabold text-base w-full" data-i18n="home.hero.visit">Open in browser ✨</a>
      <button type="button" id="a2hs-close" class="cookie-btn cookie-btn-ghost" style="width:100%;margin-top:10px" data-i18n="legal.close">Close</button>
    </div>
  </div>

  <script src="/i18n.js"></script>
  <script src="/legal.js"></script>
  <script>
    let homeLang = 'en';

    function initCookieBanner() {
      const L = window.EchelonLegal;
      const banner = document.getElementById('cookie-banner');
      if (!L || L.hasCookieConsent()) return;
      banner.hidden = false;
      const prefs = document.getElementById('cookie-prefs-panel');
      const manage = document.getElementById('cookie-manage');
      const save = document.getElementById('cookie-save');
      const accept = document.getElementById('cookie-accept');
      const reject = document.getElementById('cookie-reject');
      const functional = document.getElementById('cookie-functional');
      let managing = false;

      const hide = (consent) => {
        L.saveCookieConsent(consent);
        banner.hidden = true;
      };

      manage.addEventListener('click', () => {
        managing = !managing;
        prefs.hidden = !managing;
        manage.hidden = managing;
        accept.hidden = managing;
        reject.hidden = managing;
        save.hidden = !managing;
      });

      accept.addEventListener('click', () => hide({ functional: true, analytics: false }));
      reject.addEventListener('click', () => hide({ functional: false, analytics: false }));
      save.addEventListener('click', () => hide({ functional: functional.checked, analytics: false }));
    }

    // Language tabs + IP-based default when no preference saved
    (async function initLang() {
      const I = window.EchelonI18n;
      const L = window.EchelonLegal;
      if (!I) return;
      const tabsEl = document.getElementById('lang-tabs');
      let lang = localStorage.getItem(I.LANG_KEY);
      if (!lang || !I.LANGS.some((l) => l.id === lang)) {
        const consent = L?.getCookieConsent();
        const fromIp = consent?.functional ? await I.detectLangFromIp() : null;
        lang = fromIp || I.langFromBrowser();
        localStorage.setItem(I.LANG_KEY, lang);
      }
      homeLang = lang;

      function renderTabs() {
        if (!tabsEl) return;
        tabsEl.innerHTML = '';
        I.LANGS.forEach(({ id, label }) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'langtab' + (lang === id ? ' on' : '');
          btn.textContent = label;
          btn.setAttribute('role', 'tab');
          btn.setAttribute('aria-selected', lang === id ? 'true' : 'false');
          btn.addEventListener('click', () => {
            lang = id;
            homeLang = id;
            I.saveLang(id, true);
            I.applyHomeI18n(lang);
            renderTabs();
          });
          tabsEl.appendChild(btn);
        });
      }
      I.applyHomeI18n(lang);
      renderTabs();
      initCookieBanner();
      initA2hsButtons();
    })();

    function initA2hsButtons() {
      const modal = document.getElementById('a2hs-modal');
      const stepsEl = document.getElementById('a2hs-steps');
      const closeBtn = document.getElementById('a2hs-close');
      if (!modal || !stepsEl) return;

      const I = window.EchelonI18n;
      const t = (k) => (I && I.t ? I.t(homeLang, k) : k);
      const isIos = /iphone|ipad|ipod/i.test(navigator.userAgent);
      const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;

      function renderSteps() {
        stepsEl.innerHTML = isIos
          ? `<li>${t('pwa.iosStep1')}</li><li>${t('pwa.iosStep2')}</li>`
          : `<li>${t('pwa.androidStep')}</li>`;
      }

      function openModal() {
        renderSteps();
        modal.classList.add('open');
        modal.setAttribute('aria-hidden', 'false');
      }
      function closeModal() {
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
      }

      async function onInstallClick() {
        if (isStandalone) {
          window.location.href = '/app/';
          return;
        }
        window.location.href = '/app/?install=1';
      }

      ['a2hs-hero-btn', 'a2hs-footer-btn'].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('click', onInstallClick);
      });
      closeBtn?.addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

      if (isStandalone) {
        ['a2hs-hero-btn', 'a2hs-footer-btn'].forEach((id) => {
          const el = document.getElementById(id);
          if (el) el.style.display = 'none';
        });
      }
    }

    // Check if device supports hover/fine pointer
    const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;

    // 1. Mouse Tracking Parallax for Hero Card
    if (!isTouchDevice) {
      document.addEventListener('mousemove', (e) => {
        const card = document.getElementById('tilt-card');
        if (!card) return;
        
        // Calculate mouse position relative to the center of the window
        const xAxis = (window.innerWidth / 2 - e.pageX) / 40;
        const yAxis = (window.innerHeight / 2 - e.pageY) / 40;
        
        card.style.transform = `rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
      });

      document.addEventListener('mouseleave', () => {
        const card = document.getElementById('tilt-card');
        if (card) card.style.transform = `rotateY(0deg) rotateX(0deg)`;
      });

      // Subtle tilt for feature cards
      const featureCards = document.querySelectorAll('.tilt-feature');
      featureCards.forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = ((y - centerY) / centerY) * -5;
          const rotateY = ((x - centerX) / centerX) * 5;
          
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-12px)`;
        });
        
        card.addEventListener('mouseleave', () => {
          card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) translateY(0px)`;
        });
      });
    }

    // 2. Cursor Aura Follower (Desktop only)
    const cursorGlow = document.getElementById('cursor-glow');
    if (!isTouchDevice) {
      document.addEventListener('mousemove', (e) => {
        cursorGlow.style.left = e.clientX + 'px';
        cursorGlow.style.top = e.clientY + 'px';
      });
    } else {
      cursorGlow.style.display = 'none';
    }

    // 3. Scroll Reveal Animations
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach((el) => {
      observer.observe(el);
    });

    // 4. Navbar Blur on Scroll
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.style.background = 'rgba(255, 255, 255, 0.6)';
        navbar.style.boxShadow = '0 10px 30px rgba(0,0,0,0.05)';
      } else {
        navbar.style.background = 'rgba(255, 255, 255, 0.4)';
        navbar.style.boxShadow = '0 4px 30px rgba(0,0,0,0.02)';
      }
    });
  </script>

</body>
</html>