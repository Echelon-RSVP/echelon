          <svg viewBox="0 0 16 19" class="w-5 h-5 fill-gray-700"><path d="M13.18 14.62c-.27.62-.4.9-.74 1.45-.48.77-1.16 1.73-2 1.74-.75.01-.94-.49-1.96-.48-1.02 0-1.23.49-1.98.48-.84-.01-1.48-.87-1.96-1.64-1.34-2.16-1.48-4.7-.65-6.05.58-.96 1.5-1.52 2.36-1.52.88 0 1.43.48 2.16.48.7 0 1.13-.48 2.15-.48.77 0 1.59.42 2.17 1.14-1.9 1.04-1.6 3.76.25 4.45z"/><path d="M10.4 4.2c.42-.54.74-1.3.65-2.07-.68.05-1.48.48-1.95 1.04-.42.5-.78 1.26-.68 2 .73.06 1.5-.42 1.98-.97z"/></svg>
          <span data-i18n="home.hero.download">Download iOS</span>
